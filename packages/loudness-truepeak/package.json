{
  "name": "@audio/loudness-truepeak",
  "version": "1.1.3",
  "description": "True peak (dBTP) — 4× sinc-oversampled inter-sample peak (BS.1770-4 Annex 2 methodology)",
  "type": "module",
  "sideEffects": false,
  "main": "truepeak.js",
  "exports": {
    ".": "./truepeak.js",
