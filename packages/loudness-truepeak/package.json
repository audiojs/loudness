  },
  "files": [
    "truepeak.js",
    "audio.js",
    "audio.d.ts",
    "index.d.ts"
  ],
  "types": "index.d.ts",
  "dependencies": {
    "@audio/resample-sinc": "^1.0.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "loudness",
    "truepeak"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/loudness.git",
    "directory": "packages/loudness-truepeak"
  },
  "funding": "https://github.com/sponsors/audiojs"
}
